# Binaries
bin/
*.exe
*.dll
*.so
*.dylib
*.test

# Output of go coverage
coverage.*
*.out

# Environment files
.env
.env.*
!.env.example

# Task
.task/

# Dependency directories
vendor/
.kilo/node_modules

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Go workspace
*.code-workspace
go.work
go.work.sum

# GoReleaser (root output only)
/dist/

# Go test fixtures / generated
testdata/

# Profiling output
*.prof

# Frontend (Angular)
frontend/node_modules/
frontend/.angular/
frontend/coverage/
frontend/dist/

# Embedded SPA build output — ignore the whole tree except the committed .gitkeep.
# The Go binary needs dist/browser to exist for //go:embed; the real build is
# produced by `task build` and served at runtime, with a built-in fallback page
# when the frontend hasn't been built yet.
/backend/internal/web/dist/*
!/backend/internal/web/dist/browser
/backend/internal/web/dist/browser/*
!/backend/internal/web/dist/browser/.gitkeep
